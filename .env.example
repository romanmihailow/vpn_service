# Copy to .env and fill. Do not commit .env (it is in .gitignore).
# For container/CI: set these as environment variables (secrets).

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=0

# AI Support (optional; without it AI-support uses only rule-based answers)
OPENAI_API_KEY=

# WireGuard
WG_INTERFACE_NAME=wg0
WG_SERVER_PUBLIC_KEY=
WG_SERVER_ENDPOINT=

# Payments / webhooks
YOOKASSA_WEBHOOK_SECRET=
TRIBUTE_WEBHOOK_SECRET=

# Heleket (if used)
# HELEKET_API_KEY=
# HELEKET_MERCHANT_ID=
# HELEKET_API_PAYMENT_KEY=
